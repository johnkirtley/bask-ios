{
  "name": "bask",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "ios": "next build && npx cap sync ios; node scripts/patch-capacitor-config.js",
    "ios:open": "npx cap open ios",
    "android": "next build && npx cap sync android",
    "sync:ios": "npx cap sync ios; node scripts/patch-capacitor-config.js",
    "copy-out": "mv out/_next out/next && sed -i '' -e 's/\\/_next/\\.\\/next/g' out/**.html && mv out/index.html ./extension && rsync -va --delete-after out/next/ ./extension/next/ && rm -rf out",
    "copy-public": "cp public/images/* extension/images",
    "lint": "next lint",
    "test:leaderboard": "node scripts/test-leaderboard.mjs",
    "seed:leaderboard": "node scripts/seed-leaderboard.mjs"
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "^8.0.0",
    "@capacitor-community/sqlite": "^7.0.3",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ionic/react": "^8.2.6",
    "@revenuecat/purchases-capacitor": "^12.0.1",
    "@revenuecat/purchases-capacitor-ui": "^12.0.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "20.5.8",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.15",
    "daisyui": "^3.6.4",
    "eslint": "8.48.0",
    "eslint-config-next": "13.4.19",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "next": "13.4.19",
    "postcss": "8.4.29",
    "posthog-js": "^1.376.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.3.3",
    "typescript": "^4.9.5",
    "unique-names-generator": "^4.7.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0"
  }
}
